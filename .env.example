# Copy this file to .env (or set these as real environment variables on
# your hosting platform). Nothing here is required for the app to boot —
# everything degrades gracefully when unset, as described in README.md.

# --- Core ---
SECRET_KEY=change-this-to-a-long-random-string-in-production
PORT=5000
# FLASK_DEBUG=1            # local development only - never set this in production

# --- Stripe billing (omit to keep "Pricing" page informational-only) ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
PRO_PRICE_DISPLAY=49

# --- Outbound email for password resets + watchlist alerts ---
# Any standard SMTP provider works. Recommendation if you don't have one:
# Resend (resend.com) - simplest signup, generous free tier, standard SMTP relay.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Sanctum <alerts@yourdomain.com>"
SMTP_USE_TLS=true

# --- Watchlist monitoring cron job ---
# Required for /jobs/run-watchlist-check to accept requests. Generate any
# long random string, e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=
APP_BASE_URL=https://yourapp.com

# --- Optional extra sanctions source ---
EU_SANCTIONS_TOKEN=

# --- Database ---
DATABASE_PATH=app.db
